# Kopiera till .env.local och fyll i säkra värden
APP_URL=http://localhost/GYMNASIEARBETE1/web
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_SECURE=tls
MAIL_USERNAME=din-adress@example.com
MAIL_PASSWORD=ditt-app-losenord
MAIL_FROM=din-adress@example.com
MAIL_FROM_NAME=NeuralText AI
# Sätt till 1 för testläge: samma e-post/användarnamn kan registreras igen.
ALLOW_TEST_REREGISTRATION=0
# Sätt till 1 vid felsökning
# MAIL_DEBUG=1
